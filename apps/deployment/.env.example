# ── Domain & SSL (prod only) ────────────────────────────────────────
DOMAIN=focusread.example.com
EMAIL=admin@example.com

# ── PostgreSQL ──────────────────────────────────────────────────────
POSTGRES_USER=focusread
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=focusread

# ── Redis ───────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD
REDIS_MAXMEMORY=1gb
REDIS_MEMORY_LIMIT=1536m
REDIS_MAXMEMORY_POLICY=allkeys-lru

# ── Monitoring ──────────────────────────────────────────────────────
# Grafana admin credentials are only used on the first startup while
# the grafana_data volume is still empty.
GRAFANA_ADMIN_USER=focusread-admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_ADMIN_PASSWORD
GRAFANA_ADMIN_EMAIL=ops@example.com
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=15d
LOKI_PORT=3100
ALLOY_PORT=12345

# ── Application ─────────────────────────────────────────────────────
CORS_ORIGINS=https://focusread.example.com
FRONTEND_URL=https://focusread.example.com
ALLOWED_HOSTS=focusread.example.com

# ── OAuth (optional) ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
