# ── App ──────────────────────────────────────────────────────────────
APP_NAME=FocusRead API
APP_VERSION=0.1.0
ENVIRONMENT=local
DEBUG=true
API_V1_PREFIX=/api/v1
ALLOWED_HOSTS=*
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
REQUEST_ID_MAX_LENGTH=100
API_RATE_LIMIT_DEFAULT=80/minute

# ── Storage ─────────────────────────────────────────────────────────
STORAGE_BACKEND=local

# ── Database (PostgreSQL) ───────────────────────────────────────────
DB_EAGER_CONNECT=false
DB_ECHO=false
POSTGRES_SERVER=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=focusread
POSTGRES_PASSWORD=change_me
POSTGRES_DB=focusread

# ── Redis ───────────────────────────────────────────────────────────
REDIS_EAGER_CONNECT=false
CACHE_DEFAULT_TTL_SECONDS=1800
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CACHE_DB=0
REDIS_CELERY_BROKER_DB=1
REDIS_CELERY_RESULT_DB=2
REDIS_KEY_PREFIX=focusread

# ── Celery ──────────────────────────────────────────────────────────
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_TIME_LIMIT=1800

# ── JWT / Auth ──────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_KEY_PAIR_CACHE_TTL_SECONDS=86400
FRONTEND_URL=http://localhost:3000
# Production forces secure cookies even when this stays false.
AUTH_COOKIE_SECURE=false

# ── OAuth Providers (optional) ──────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
